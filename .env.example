# Optional — copy to .env
XSP_LANE_A_PAPER_ENTRY=true
XSP_LANE_A_RH_POLL=false
XSP_LANE_B_RH_POLL=false
XSP_LANE_A_RH_MCP=false
XSP_LANE_A_LIVE_EXITS=false
# XSP_LANE_A_LIVE_ENTRIES=false
# Live place requires ALL THREE matching the same promoted variant id:
# XSP_LANE_A_LIVE_VARIANT_ID=v2_dip_swing_14dte
# XSP_LANE_A_LIVE_HUMAN_ACK=v2_dip_swing_14dte
# Ack file (.local/LIVE_HUMAN_REVIEW.json):
#   {"variant_id":"…","statement":"I reviewed the scoreboard and promote this variant to live"}
# XSP_LANE_A_LIVE_HUMAN_ACK_PATH=
XSP_KILLER_INTEL_DISABLED=true

# Agentic MCP (preferred over legacy poll when live)
# RH_AGENTIC_ACCOUNT_ID=
# Token file: .local/robinhood_mcp_token.json (mode 600, never commit)

# Legacy robin_stocks (deprecated after MCP read parity)
# RH_USERNAME=
# RH_PASSWORD=

# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
XSP_LANE_A_DAILY_LOSS_CAP_USD=500

# K37 reviewer v2 — shadow log-only (enforce stays off until audit gates)
REVIEWER_V2_SHADOW=true
REVIEWER_V2_ENABLED=false
