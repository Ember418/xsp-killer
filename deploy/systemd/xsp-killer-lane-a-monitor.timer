[Unit]
Description=XSP Killer Lane A morning sell window — 09:35/09:45/10:00 ET (Mon-Fri)

[Timer]
OnCalendar=Mon..Fri *-*-* 09:35:00 America/New_York
OnCalendar=Mon..Fri *-*-* 09:45:00 America/New_York
OnCalendar=Mon..Fri *-*-* 10:00:00 America/New_York
Persistent=true
RandomizedDelaySec=30

[Install]
WantedBy=timers.target
